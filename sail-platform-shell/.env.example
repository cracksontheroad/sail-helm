# SAIL Helm — environment template
#
# Copy this file to `.env` and fill in real values for local dev.
# `.env` is gitignored (covered by `.env*` in sail-platform-shell/.gitignore).
#
# IMPORTANT: do not commit real keys to this repository. Server-side
# secrets (anything without the `VITE_` prefix) live ONLY in:
#   - local `.env` for `netlify dev`
#   - Netlify dashboard → Site settings → Environment variables for prod
#
# Vite inlines `VITE_*` env values at build time — they ship in the
# client bundle. Anything else stays server-side. Both Helm builds (dev
# + prod) must rebuild after changing values here.

# ─── Server-side (Netlify Functions only — not bundled to browser) ────────────
#
# OPENAI_API_KEY is consumed by netlify/functions/ai-proxy.js when a
# request hits the legacy fallback path. Phase B4 (Stage 2 Helm
# stabilisation) deletes that function entirely; after B4 lands, this
# variable is unused and can be removed from the deployment.
#
# Until B4 lands, the variable is OPTIONAL — if every school has
# `ai_grading` enabled in `school_apps` (Phase B1 condition, true as of
# 2026-05-07) AND VITE_STRICT_AI_PROXY=true (Phase B2), the fallback
# is unreachable and the key is never consulted at runtime.
#
# OPENAI_API_KEY=sk-proj-…


# ─── Client-side (VITE_* — bundled into browser code) ────────────────────────
#
# Strict AI proxy mode (Phase B2, Stage 2 Helm stabilisation):
# When `true`, services/ai.js disables the legacy Netlify-function
# fallback. APP_NOT_ENABLED + every other failure mode propagates as a
# normalised teacher-safe Error with stable .type / .originalCode.
#
# Default-deny: missing or non-`true` value resolves to `false` (legacy
# behaviour preserved). The literal string `'true'` is the only enable
# value — `1`, `on`, `yes` all read as false.
#
# Rebuild required after changing this value (Vite inlines at build
# time). Production: set in Netlify dashboard env vars.
VITE_STRICT_AI_PROXY=true

# Deployment-mode tag, surfaced into ai_requests metadata via
# pages/Assignments.jsx so per-deploy traffic is filterable in DB.
# Set to a stable identifier per environment: dev / staging / prod.
# VITE_DEPLOYMENT_MODE=dev
