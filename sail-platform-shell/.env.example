# Helm — environment template.
#
# Local dev:  cp .env.example .env (or .env.local) and fill in real values.
# CI:         set these as GitHub repo secrets (Settings -> Secrets -> Actions)
#             and the workflow injects them into the Build step.
#
# Both .env and .env.* are gitignored; .env.example is the only env file
# that gets committed.

# Vite reads VITE_*-prefixed vars at build time and inlines them into the
# client bundle. The anon key is *publishable* (not a secret in the OAuth
# sense — it ships in every browser), but it's still configured via env
# so different builds (staging, production) can target different projects.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional. Overrides the fixture-user password used by the Playwright
# E2E suite (sail-platform-shell/e2e/helpers.js). If unset, the suite
# falls back to the literal default committed in helpers.js.
E2E_TEST_PASSWORD=
