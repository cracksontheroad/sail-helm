# SAIL Helm — environment template
#
# Copy this file to `.env` and fill in real values for local dev.
# `.env` is gitignored (covered by `.env*` in sail-platform-shell/.gitignore).
#
# IMPORTANT: do not commit real keys to this repository. Server-side
# secrets (anything without the `VITE_` prefix) live ONLY in:
#   - local `.env` for `netlify dev`
#   - Netlify dashboard → Site settings → Environment variables for prod
#
# Vite inlines `VITE_*` env values at build time — they ship in the
# client bundle. Anything else stays server-side. Both Helm builds (dev
# + prod) must rebuild after changing values here.

# ─── Server-side (Netlify Functions only — not bundled to browser) ────────────
#
# OPENAI_API_KEY is consumed by netlify/functions/ai-proxy.js when a
# request hits the legacy fallback path. Phase B4 (Stage 2 Helm
# stabilisation) deletes that function entirely; after B4 lands, this
# variable is unused and can be removed from the deployment.
#
# Until B4 lands, the variable is OPTIONAL — if every school has
# `ai_grading` enabled in `school_apps` (Phase B1 condition, true as of
# 2026-05-07) AND VITE_STRICT_AI_PROXY=true (Phase B2), the fallback
# is unreachable and the key is never consulted at runtime.
#
# OPENAI_API_KEY=sk-proj-…


# ─── Client-side (VITE_* — bundled into browser code) ────────────────────────
#
# Phase B4-prep (2026-05-07): proxy-only feature flag.
#
# When `true`, services/ai.js disables the legacy Netlify-function
# fallback path:
#   * APP_NOT_ENABLED throws an explicit `[USE_AI_PROXY_ONLY] fallback
#     blocked` error mentioning the school_id (actionable for ops).
#   * Other proxy errors normalize via normalizeAIError() before
#     throwing (stable teacher-readable .message + .type / .originalCode).
#   * EXCEPTION (transient safety override): if the proxy returns
#     PROVIDER_ERROR with the literal "OPENAI_API_KEY not configured"
#     message, the fallback STILL fires regardless of this flag.
#     This prevents accidental outage during a config rollout where
#     the Edge-Function secret hasn't yet been set. The override is
#     removed in Phase B4 itself when the Netlify function is deleted.
#
# When `false` (default), preserves Slice-11 scoped-fallback behaviour:
#   * APP_NOT_ENABLED falls back to the Netlify function (logs
#     `proxy_error_fallback_used`).
#   * All other proxy errors propagate raw to the caller.
#
# Outcome logs (one line per call, structured, `[ai-proxy] *` prefix):
#   proxy_success                  primary path ok
#   proxy_safety_fallback_used     OPENAI_API_KEY missing → fallback fired
#   proxy_error_fallback_used      APP_NOT_ENABLED + flag=false → fallback
#   proxy_error_no_fallback        any other failure (incl. flag=true paths)
#
# Default-deny: missing or non-`true` value resolves to `false`. The
# literal string `'true'` is the only enable value. Vite inlines this
# at build time — rebuild required after changing.
#
# Cutover sequence:
#   1) OPENAI_API_KEY set on Supabase Edge Function (one-time)
#   2) Live authenticated probe lands status='success' in ai_requests
#   3) Flip this to `true`, rebuild, deploy, monitor
#   4) Phase B4: delete Netlify function + this whole block + safety override
VITE_USE_AI_PROXY_ONLY=false

# DEPRECATED ALIAS — Phase B2 (2026-05-07) introduced VITE_STRICT_AI_PROXY
# which has been superseded by VITE_USE_AI_PROXY_ONLY above. The codebase
# still honours the old name as equivalent for one cycle so a stale .env
# doesn't fail open. Remove this line in the cycle after Phase B4. Do NOT
# set both — pick the new name.
# VITE_STRICT_AI_PROXY=true

# Deployment-mode tag, surfaced into ai_requests metadata via
# pages/Assignments.jsx so per-deploy traffic is filterable in DB.
# Set to a stable identifier per environment: dev / staging / prod.
# VITE_DEPLOYMENT_MODE=dev
